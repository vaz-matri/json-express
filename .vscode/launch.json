{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Server (Example Dir)",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/packages/core/bin/exec.js",
      "cwd": "${workspaceFolder}/example",
      "restart": true,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Server (json-adv)",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/packages/core/bin/exec.js",
      "cwd": "${workspaceFolder}/example/json-adv",
      "restart": true,
      "console": "integratedTerminal"
    }
  ]
}
