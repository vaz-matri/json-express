JEX__AUTH__SECRET=preset-identity-example-secret

# Path prefixes that bypass middleware-auth. /auth is mandatory — register/login
# routes can't gate themselves on a Bearer token (chicken-and-egg).
JEX__AUTH__EXCLUDE=/auth

# Issuer + audience claims are stamped into every JWT plugin-identity issues
# AND verified by middleware-auth on every request. A token forged with the
# wrong iss/aud is rejected even if it's signed with the right secret.
JEX__AUTH__ISSUER=preset-identity-example
JEX__AUTH__AUDIENCE=preset-identity-clients
