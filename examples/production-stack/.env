jex.adapter=@json-express/adapter-postgres
jex.adapter-postgres.connectionString=postgres://postgres:postgres@localhost:5432/json_express_prod

jex.queue=@json-express/queue-bullmq
jex.queue-bullmq.connectionString=redis://localhost:6379

jex.kv=@json-express/kv-redis
jex.kv-redis.connectionString=redis://localhost:6379
