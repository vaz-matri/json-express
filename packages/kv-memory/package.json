{
  "name": "@json-express/kv-memory",
  "version": "2.0.0",
  "description": "In-memory key-value store for JSON Express — zero-dependency, TTL-aware. Default for local dev.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  },
  "files": [
    "dist",
    "llms.txt",
    "skills"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "key-value",
    "kv-store",
    "ttl",
    "in-memory-cache"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  }
}
