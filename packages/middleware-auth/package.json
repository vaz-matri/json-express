{
  "name": "@json-express/middleware-auth",
  "version": "2.0.0",
  "description": "JWT Authentication Middleware plugin for JSON Express",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.4",
    "@json-express/core": "workspace:^"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "jwt",
    "authentication",
    "jwks",
    "auth0",
    "bearer-token"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  }
}
