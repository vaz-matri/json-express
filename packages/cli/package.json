{
  "name": "@json-express/cli",
  "version": "2.0.0-alpha.0",
  "description": "Developer workflow utility for JSON Express (scaffold projects, export collections to typed models). The server itself runs via the json-express binary shipped by @json-express/core.",
  "type": "module",
  "bin": {
    "jex": "./bin/jex.js"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9"
  },
  "files": [
    "bin",
    "dist"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "cli",
    "command-line",
    "scaffolding",
    "developer-tools"
  ]
}
