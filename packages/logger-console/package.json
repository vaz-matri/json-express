{
  "name": "@json-express/logger-console",
  "version": "2.0.0",
  "description": "Standard console logger for JSON Express v2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "logging",
    "console-logger",
    "zero-dependency"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  }
}
