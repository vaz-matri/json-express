{
  "name": "@json-express/config-env",
  "version": "2.0.0",
  "description": "Default Environment Configuration plugin for JSON Express",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  },
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  },
  "files": [
    "dist",
    "llms.txt",
    "skills"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "dotenv",
    "environment-variables",
    "twelve-factor",
    "spring-boot"
  ]
}
