{
  "name": "@json-express/api-rest",
  "version": "2.0.0",
  "description": "REST API Generator plugin for JSON Express",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "rest-generator",
    "crud-api",
    "express-rest",
    "route-generator"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  }
}
