{
  "name": "@json-express/adapter-json",
  "version": "2.0.0",
  "description": "Persistent JSON file database adapter for JSON Express v2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "llms.txt"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  },
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "json-database",
    "file-database",
    "git-backed-cms",
    "persistent"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  }
}
