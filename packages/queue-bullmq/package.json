{
  "name": "@json-express/queue-bullmq",
  "version": "1.0.0",
  "description": "BullMQ distributed queue adapter for JSONExpress",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "bullmq": "^5.7.0",
    "ioredis": "^5.3.2"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "json-express",
    "redis",
    "queue",
    "bullmq",
    "distributed-queue"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  }
}
