{
  "name": "@json-express/api-graphql",
  "version": "2.0.0",
  "description": "GraphQL API Generator plugin for JSON Express",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "graphql": "^16.8.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.4",
    "jsonwebtoken": "^9.0.2",
    "@json-express/core": "workspace:^"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "graphql-generator",
    "graphql-api",
    "graphql-server",
    "sdl"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  }
}
