{
  "name": "@json-express/transport-fastify",
  "version": "2.0.0",
  "description": "High-performance Fastify transport plugin for JSON Express v2",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "llms.txt",
    "skills"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  },
  "dependencies": {
    "fastify": "^5.3.3"
  },
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "fastify",
    "fastify-plugin",
    "high-performance",
    "transport"
  ]
}
