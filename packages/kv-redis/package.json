{
  "name": "@json-express/kv-redis",
  "version": "1.0.0",
  "description": "Redis-backed ephemeral key-value store adapter for JSONExpress",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "ioredis": "^5.3.2"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "keywords": [
    "json-express",
    "redis",
    "kv-store",
    "cache"
  ],
  "peerDependencies": {
    "@json-express/core": "workspace:^"
  },
  "devDependencies": {
    "@json-express/core": "workspace:^"
  }
}
