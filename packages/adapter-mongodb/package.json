{
  "name": "@json-express/adapter-mongodb",
  "version": "1.0.0",
  "description": "MongoDB database adapter for JSONExpress",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "dependencies": {
    "@json-express/core": "workspace:*",
    "mongodb": "^6.5.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "json-express",
    "mongodb",
    "database-adapter"
  ]
}
