{
  "name": "@json-express/plugin-devcert",
  "version": "2.0.0",
  "description": "Automatic Local HTTPS via Devcert",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --clean --dts --format esm --format cjs",
    "dev": "tsdown src/index.ts --watch --dts --format esm --format cjs"
  },
  "devDependencies": {},
  "dependencies": {
    "devcert": "^1.2.2",
    "@json-express/core": "workspace:*"
  },
  "keywords": [
    "json-express",
    "jsonexpress",
    "headless-cms",
    "rest-api",
    "graphql",
    "typescript",
    "nodejs",
    "api-generator",
    "mock-api",
    "backend-framework",
    "https",
    "ssl",
    "localhost-ssl",
    "devcert"
  ]
}
